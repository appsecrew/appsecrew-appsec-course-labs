{
  "name": "nodejs-gateway-lab",
  "version": "1.0.0",
  "description": "Node.js API Gateway with SSRF vulnerabilities for security testing",
  "main": "src/gateway/app.js",
  "scripts": {
    "start:all": "concurrently \"npm run start:auth\" \"npm run start:users\" \"npm run start:admin\" \"npm run start:metadata\" \"npm run start:gateway\"",
    "dev": "concurrently \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:users\" \"npm run start:admin\" \"npm run start:metadata\"",
    "start": "node src/gateway/app.js",
    "start:gateway": "node src/gateway/app.js",
    "start:auth": "node src/services/auth-service.js",
    "start:users": "node src/services/user-service.js",
    "start:admin": "node src/services/admin-service.js",
    "start:metadata": "node src/internal/metadata-service.js",
    "db:init": "node src/utils/database.js init",
    "db:reset": "node src/utils/database.js reset",
    "db:seed": "node src/utils/database.js seed",
    "test:api": "node tests/integration-tests.js",
    "test:ssrf": "node tests/ssrf-tests.js",
    "security:scan": "node tests/security-scan.js",
    "monitor:memory": "node --inspect src/gateway/app.js"
  },
  "keywords": [
    "nodejs",
    "api-gateway",
    "ssrf",
    "security",
    "microservices",
    "vulnerability"
  ],
  "author": "Security Lab",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "axios": "^1.5.0",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "jest": "^29.6.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
