<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SecureBank</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <style>
        .vuln-badge { background: #dc3545; color: #fff; padding: 2px 8px; border-radius: 3px; font-size: .8em; }
    </style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/Dashboard">
            <i class="bi bi-bank"></i> SecureBank
            <span class="vuln-badge ms-2">CSRF LAB</span>
        </a>
        <div class="d-flex align-items-center">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <ul class="navbar-nav flex-row me-3">
                    <li class="nav-item me-3"><a class="nav-link text-light" href="/Dashboard">Dashboard</a></li>
                    <li class="nav-item me-3"><a class="nav-link text-light" href="/Transfer">Transfer</a></li>
                    <li class="nav-item me-3"><a class="nav-link text-light" href="/BillPayment">Pay Bills</a></li>
                    <li class="nav-item me-3"><a class="nav-link text-light" href="/Transfer/History">History</a></li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item me-3"><a class="nav-link text-warning" href="/Admin">Admin</a></li>
                    }
                </ul>
                <span class="text-light small me-2">@User.Identity.Name</span>
                <form method="post" action="/Account/Logout" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline-light btn-sm me-2">Login</a>
                <a href="/Account/Register" class="btn btn-light btn-sm">Register</a>
            }
        </div>
    </div>
</nav>

<div class="container py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @RenderBody()
</div>

<footer class="bg-light py-3 mt-4">
    <div class="container text-center text-muted small">
        SecureBank Training Lab — <a href="/wwwroot/lab-guide.html">Lab Guide</a> | <a href="/wwwroot/csrf-demo.html">CSRF Demo Page</a>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
