@model SecureBankingApp.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-lock"></i> Login</h5></div>
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                <!-- VULNERABLE: No @Html.AntiForgeryToken() -->
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com"/>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" type="password"/>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input"/>
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>

                <hr/>
                <p class="text-center"><a asp-action="Register">Create new account</a></p>
            </div>
        </div>

        <div class="card mt-3 border-warning">
            <div class="card-body">
                <strong>Test Accounts:</strong>
                <ul class="small mb-0">
                    <li><code>user@securebank.com / User123!</code> — Customer</li>
                    <li><code>alice@securebank.com / Alice123!</code> — Customer ($2,500)</li>
                    <li><code>bob@securebank.com / Bob123!</code> — Customer ($5,000)</li>
                    <li><code>admin@securebank.com / Admin123!</code> — Admin</li>
                </ul>
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/lab-guide.html" class="btn btn-outline-secondary btn-sm">Lab Guide</a>
            <a href="/csrf-demo.html" class="btn btn-outline-danger btn-sm ms-2">CSRF Demo</a>
        </div>
    </div>
</div>
