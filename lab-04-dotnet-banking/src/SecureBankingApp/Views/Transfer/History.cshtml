@model List<SecureBankingApp.Models.Transaction>
@{ ViewData["Title"] = "Transaction History"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="d-flex justify-content-between mb-3">
    <h4>Transaction History</h4>
    <a href="/Transfer" class="btn btn-outline-primary btn-sm">New Transfer</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Date</th><th>From</th><th>To</th><th>Amount</th><th>Description</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var tx in Model)
                {
                    <tr>
                        <td>@tx.TransactionDate.ToString("MM/dd HH:mm")</td>
                        <td class="font-monospace">@(tx.FromAccount?.AccountNumber ?? "-")</td>
                        <td class="font-monospace">@(tx.ToAccount?.AccountNumber ?? "-")</td>
                        <td class="text-danger fw-bold">@tx.Amount.ToString("C")</td>
                        <td>@tx.Description</td>
                        <td><span class="badge @(tx.Status == SecureBankingApp.Models.TransactionStatus.Completed ? "bg-success" : "bg-warning text-dark")">@tx.Status</span></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center py-3 text-muted">No transactions</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
